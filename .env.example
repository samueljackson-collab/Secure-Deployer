# Secure Deployment Runner — Environment Variables
# Copy this file to .env for local development: cp .env.example .env
#
# IMPORTANT SECURITY NOTICE
# ==========================
# This application is designed to run fully offline / air-gapped.
# NO API keys, secrets, tokens, or credentials should ever appear here.
# The .env file is listed in .gitignore and must never be committed.
#
# AI integrations have been permanently removed from this project.
# Do not add GEMINI_API_KEY, OPENAI_API_KEY, or any similar variable.

# Optional: override the session idle-timeout (milliseconds).
# Default is 900000 (15 minutes). Set to 0 to disable.
# VITE_APP_SESSION_TIMEOUT_MS=900000
